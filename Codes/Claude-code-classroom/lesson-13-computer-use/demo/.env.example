# ==========================================
# ENVIRONMENT CONFIGURATION

# ----- AUTHENTICATION -----
# In Vocareum workspace: ANTHROPIC_API_KEY and ANTHROPIC_BASE_URL
# are already set in your environment. Do NOT add them here.
#
# For local development, uncomment and fill in:
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_BASE_URL=your-base-url-here

# Required for all environments — copy .env.example to .env:
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ----- COMPUTER USE SETTINGS -----
# Display dimensions for the virtual environment
DISPLAY_WIDTH=1024
DISPLAY_HEIGHT=768
