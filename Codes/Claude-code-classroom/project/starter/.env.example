# ==========================================
# ENVIRONMENT CONFIGURATION
# ==========================================

# ----- AUTHENTICATION -----
# In Vocareum workspace: ANTHROPIC_API_KEY and ANTHROPIC_BASE_URL
# are already set in your environment. Do NOT add them here.
#
# For local development with your own API key:
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ----- MODEL CONFIGURATION (REQUIRED) -----
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Available models:
#   - claude-sonnet-4-5-20250929 (recommended)
#   - claude-haiku-4-5-20251001 (faster, cheaper)

# ----- PROJECT ROOT (REQUIRED) -----
# Absolute path to the project/starter directory
# This directory MUST contain the .claude/skills/ directory

# Vocareum workspace:
PROJECT_ROOT=/voc/work/cd14715-claude-code-classroom/project/starter

# Local development (update to your path):
# PROJECT_ROOT=/absolute/path/to/project/starter

# ----- GITHUB TOKEN (RECOMMENDED) -----
# For higher rate limits and private repository access
# Generate at: https://github.com/settings/tokens
# Required scopes: 'repo', 'read:org'
# GITHUB_TOKEN=ghp_your-token-here

# ----- LOGGING (OPTIONAL) -----
# Options: error, warn, info, debug
LOG_LEVEL=info